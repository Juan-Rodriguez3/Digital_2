	      }
	      sChange_F1 = 0;
	  }
	  // --- Lógica enemigos nivel 2 (spikes) ---
	  if (nivelA == 2)
	  {
	      counterT++;
	      if (counterT == 150)
	      {
	          uint8_t coli = 1;
