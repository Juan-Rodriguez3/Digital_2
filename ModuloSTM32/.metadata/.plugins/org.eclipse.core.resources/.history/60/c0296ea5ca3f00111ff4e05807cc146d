void generarSin(){
    for (int x = 0; x < size; x++){
    	Ysine[x] = (uint32_t)(2048+2047 * sin(2.0 * pi * x / size));
    	Ysilencio[x] = 0;
    }
}

void generateNoise()
{
    for(int i = 0; i < size; i++)
    {
        Ynoise[i] = rand() % 4096; // DAC 12 bits
    }
}

// Corrección — silencio real:
void playToneDAC(uint32_t ARR, uint8_t sDac)
{
	if (sDac==1){
	    if(ARR == 0)
	    {
	        HAL_TIM_Base_Stop(&htim6);
	        HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_1);

	        __HAL_TIM_SET_AUTORELOAD(&htim6, 99);
	        __HAL_TIM_SET_COUNTER(&htim6, 0);
	        HAL_TIM_Base_Start(&htim6);
	        HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_1,
	                          (uint32_t*)Ysilencio, size, DAC_ALIGN_12B_R);
	        return;
	    }

	    HAL_TIM_Base_Stop(&htim6);
	    HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_1);

	    __HAL_TIM_SET_AUTORELOAD(&htim6, ARR);
	    __HAL_TIM_SET_COUNTER(&htim6, 0);

	    HAL_TIM_Base_Start(&htim6);
	    HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_1,
	                      (uint32_t*)Ysine, size, DAC_ALIGN_12B_R);
	}
	else if (sDac==2){
	    if(ARR == 0)
	    {
	        HAL_TIM_Base_Stop(&htim7);
	        HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_2);

	        __HAL_TIM_SET_AUTORELOAD(&htim7, 99);
	        __HAL_TIM_SET_COUNTER(&htim7, 0);
	        HAL_TIM_Base_Start(&htim7);
	        HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_2,
	                          (uint32_t*)Ysilencio, size, DAC_ALIGN_12B_R);
	        return;
	    }

	    HAL_TIM_Base_Stop(&htim7);
	    HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_2);

	    __HAL_TIM_SET_AUTORELOAD(&htim7, ARR);
	    __HAL_TIM_SET_COUNTER(&htim7, 0);

	    HAL_TIM_Base_Start(&htim7);
	    HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_2,
	                      (uint32_t*)Ysine, size, DAC_ALIGN_12B_R);
	}
}

void playSon(uint32_t cancion[], uint16_t duracion[], uint16_t sizeM)
{
    // Arrancar con silencio inicialmente
    playToneDAC(0, 1);

    for(int i = 0; i < sizeM; i++)
    {
        uint16_t dur_nota     = duracion[i] * 90 / 100UL;
        uint16_t dur_silencio = duracion[i] * 10 / 100UL;
        if(dur_silencio < 25) dur_silencio = 25;

        // Tocar nota
        playToneDAC(cancion[i],1);
        HAL_Delay(dur_nota);

        // Silencio entre notas con tabla plana
        playToneDAC(0,1);
        HAL_Delay(dur_silencio);
    }

    // Al final dejar en silencio
    playToneDAC(0,1);
}

void setAmplitude(float gain)
{
    for(int i = 0; i < size; i++)
    {
        Ysine_scaled[i] = Ysine[i] * gain;
    }
}

void swordSlash(uint32_t frequencyI, uint32_t frequencyF,uint8_t sweepA,uint8_t sweepD)
{
    for(uint32_t arr = frequencyI; arr < frequencyF; arr += sweepA)
    {
    	float gain = (float)(arr - frequencyI) / 2200.0f; // ataque
		setAmplitude(gain);
		playToneDAC(arr,2);
		HAL_Delay(2);
    }

    for(uint32_t arr = frequencyF; arr > frequencyI; arr -= sweepD)
    {
    	float gain = (float)(arr - frequencyI) / 2500.0f; // decay
		setAmplitude(gain);
		playToneDAC(arr,2);
		HAL_Delay(2);
    }

    playToneDAC(0,2); // silencio
}

void unsheath()
{
    for(uint32_t arr = 3000; arr > 500; arr -= 100)
    {
        playToneDAC(arr,2);
        HAL_Delay(2);
    }

    for(uint32_t arr = 500; arr < 1500; arr += 30)
    {
        playToneDAC(arr,2);
        HAL_Delay(3);
    }

    playToneDAC(0,2);
}

void StarPower()
{
    /*playToneDAC(2000);
    HAL_Delay(30);

    playToneDAC(1000);
    HAL_Delay(40);

    playToneDAC(0);*/
	// 1. IMPACTO (golpe inicial)
	for(uint32_t arr = 500; arr < 800; arr += 20)
	{
		playToneDAC(arr,2);
		HAL_Delay(2);
	}

	// 2. CUERPO (peso del pie)
	for(uint32_t arr = 800; arr > 200; arr -= 25)
	{
		playToneDAC(arr,2);
		HAL_Delay(3);
	}

	// 3. FRICCIÓN (ruido)
	generateNoise(); // tu función de ruido
	HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_1);

	HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_1,
					  (uint32_t*)Ynoise, size, DAC_ALIGN_12B_R);

	HAL_Delay(15);

	playToneDAC(0,2); // silencio
}

void impact()
{
    for(uint32_t arr = 500; arr < 3000; arr += 200)
    {
        playToneDAC(arr,2);
        HAL_Delay(2);
    }

    playToneDAC(0,2);
}

void Disparos()
{
	for(int i = 0; i < 3; i++)
	{
		// sweep
		for(uint32_t arr = 2500; arr > 1000; arr -= 80)
		{
			playToneDAC(arr,2);
			HAL_Delay(5);
		}

		// ruido corto (textura)
		generateNoise();
		HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_1,
						  (uint32_t*)Ynoise, size, DAC_ALIGN_12B_R);

		HAL_Delay(20);
	}

	playToneDAC(0,2);
}

void loading_tick_progressive()
{
    uint16_t tone = 1200;

    int delay_time = 120; // empieza lento

    for(int i = 0; i < 30; i++)
    {
        playToneDAC(tone,2);
        HAL_Delay(10); // tic corto

        playToneDAC(0,2);
        HAL_Delay(delay_time);

        // acelerar progresivamente
        if(delay_time > 20)
            delay_time -= 3;
    }
}

void loading_tick_pro()
{
    uint32_t base = 900;
    int delay_time = 120;

    for(int i = 0; i < 50; i++)
    {
        uint32_t tone = base + i * 10; // sube tono

        playToneDAC(tone,2);
        HAL_Delay(8);

        playToneDAC(0,2);
        HAL_Delay(delay_time);

        if(delay_time > 10)
            delay_time -= 2;
    }
}

void loading_tick_complete()
{
    loading_tick_pro();

    // sonido final
    playToneDAC(800,2);
    HAL_Delay(100);

    playToneDAC(600,2);
    HAL_Delay(150);

    playToneDAC(0,2);
}

void loading_brbr()
{
    uint32_t tone = 1000;

    for(int i = 0; i < 20; i++)
    {
        // BR
        playToneDAC(tone,2);
        HAL_Delay(20);

        playToneDAC(0,2);
        HAL_Delay(20);

        // BR (segundo pulso)
        playToneDAC(tone,2);
        HAL_Delay(20);

        playToneDAC(0,2);

        // pausa entre grupos
        HAL_Delay(100);
    }
}

void footstep()
{ // 1. IMPACTO — ataque rápido ascendente (golpe del talón)
    for(uint32_t arr = 800; arr < 1400; arr += 60)
    {
        playToneDAC(arr,2);
        HAL_Delay(1);
    }

    // 2. PESO — caída de frecuencia (peso del cuerpo sobre el pie)
    for(uint32_t arr = 1400; arr > 300; arr -= 40)
    {
        playToneDAC(arr,2);
        HAL_Delay(2);
    }

    // 3. TEXTURA — ruido de fricción del suelo
    generateNoise();
    HAL_DAC_Stop_DMA(&hdac, DAC_CHANNEL_1);
    HAL_DAC_Start_DMA(&hdac, DAC_CHANNEL_1,
                      (uint32_t*)Ynoise, size, DAC_ALIGN_12B_R);
    HAL_Delay(20);

    // 4. SILENCIO — separación entre pasos
    playToneDAC(0,2);
    HAL_Delay(180);
}

void blockHit(void)
{
    // 1. IMPACTO — golpe seco descendente
    for(uint32_t arr = ARR_La4; arr < ARR_Re3; arr += 120)
    {
        playToneDAC(arr, 2);
        HAL_Delay(2);
    }

    // 2. REBOTE — sube un poco (sensación de choque)
    for(uint32_t arr = ARR_Re3; arr > ARR_Sol3; arr -= 60)
    {
        playToneDAC(arr, 2);
        HAL_Delay(2);
    }

    // 3. CORTE — silencio brusco tipo arcade
    playToneDAC(0, 2);
    HAL_Delay(20);

    // 4. BUZZ corto — textura de bloque sólido
    for(int i = 0; i < 3; i++)
    {
        playToneDAC(ARR_Do4, 2);
        HAL_Delay(8);
        playToneDAC(0, 2);
        HAL_Delay(8);
    }

    playToneDAC(0, 2);
}

void Song_Start(uint32_t *notes, uint16_t *duration, uint16_t sizeO)
{
    song_notes    = notes;
    song_duration = duration;
    song_size     = sizeO;
    song_index    = 0;
    note_tick     = 0;
    note_phase    = 0;
    song_playing  = 1;

    // Calcular duración primera nota
    uint16_t dur = duration[0];
    note_ticks_on  = dur * 90 / 100;
    note_ticks_off = dur * 10 / 100;
    if (note_ticks_off < 25) note_ticks_off = 25;

    playToneDAC(notes[0],1);
}

void Song_Stop(void)
{
    song_playing = 0;
    song_notes   = NULL;
    playToneDAC(0,1);
}
