/* USER CODE BEGIN 4 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART2)
    {
    	HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5); // Cambia estado del LED
        if(rxData=='1'){
        	S_audio=1;
        }
        else if(rxData=='2'){
        	S_audio=2;
        }
        else {
        	S_audio=0;
        }

        HAL_UART_Receive_IT(&huart2, &rxData, 1);
    }
}
