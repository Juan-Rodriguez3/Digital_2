/* USER CODE BEGIN 4 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART1)
    {
        if (rxByte1 == '\n')
        {
            buffer1[rxIndex1] = '\0';
            rxIndex1 = 0;

            sscanf((char*)buffer1, "%d,%d,%c,%c", &nivelR, &moveR, &eventR, &skinR);

            newSonicData = 1;
        }
        else
        {
            if (rxIndex1 < sizeof(buffer1) - 1)
                buffer1[rxIndex1++] = rxByte1;
        }
        HAL_UART_Receive_IT(&huart1, &rxByte1, 1);
    }
}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM2)
    {
        if (!song_playing || song_notes == NULL) return;

        note_tick++;

        if (note_phase == 0) // Fase: tocando nota
        {
            if (note_tick >= note_ticks_on)
            {
                // Pasar a silencio entre notas
                playToneDAC(0);
                note_tick  = 0;
                note_phase = 1;
            }
        }
        else // Fase: silencio entre notas
        {
            if (note_tick >= note_ticks_off)
            {
                note_tick = 0;
                note_phase = 0;
                song_index++;

                if (song_index >= song_size)
                {
                    // Canción terminó
                    song_playing = 0;
                    playToneDAC(0);
                    // Señal para que el while(1) cargue la siguiente
                    newSonicData = 2; // valor especial: canción terminada
                    return;
                }

                // Siguiente nota
                uint16_t dur = song_duration[song_index];
                note_ticks_on  = dur * 90 / 100;
                note_ticks_off = dur * 10 / 100;
                if (note_ticks_off < 25) note_ticks_off = 25;

                playToneDAC(song_notes[song_index]);
            }
        }
    }
}
