	  if (flag_park_received){
	      flag_park_received = 0;

	      // Recorrer los 4 bits del estado remoto (parqueos 1-4)
	      for (int i = 0; i < 4; i++){
	          uint8_t bitActual  = (estadoParqueo_ESP32 >> i) & 0x01;
	          uint8_t bitAnterior = (prevEstadoESP32   >> i) & 0x01;

	          if (bitAnterior == 0 && bitActual == 1){
	              // Parqueo remoto i+1 se OCUPÓ
	              ParqDisp--;
	              l_flag = i + 1;  // parqueos 1,2,3,4 → l_flag 1,2,3,4 (LED rojo arriba)
	          }
	          else if (bitAnterior == 1 && bitActual == 0){
