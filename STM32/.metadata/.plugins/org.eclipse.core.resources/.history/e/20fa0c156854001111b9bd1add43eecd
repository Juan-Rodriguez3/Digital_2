/* USER CODE BEGIN 0 */
void update_neopixels(){
	pixelClear();
	setPixelColor(0, RGB1[0], RGB1[1],RGB1[2]);
	setPixelColor(1, RGB2[0], RGB2[1],RGB2[2]);
	setPixelColor(2, RGB3[0], RGB3[1],RGB3[2]);
	setPixelColor(3, RGB4[0], RGB4[1],RGB4[2]);
	setBrightness(70);
	pixelShow();
}

//Esta funcion es para facilitar el cambio de color en base a flags
void update_colors(uint8_t flagSensor, uint8_t RGB[3],uint8_t compare){
	if ((flagSensor & compare) == compare){
		  RGB[1]=0;
		  RGB[0]=255;
	  }
	  else if ((flagSensor & (compare<<4)) == (compare<<4)){
		  RGB[0]=0;
		  RGB[1]=255;
	  }
}

void update_park(uint8_t flagSensor){
	update_colors(flagSensor, RGB1,0x01);
	update_colors(flagSensor, RGB2,0x02);
	update_colors(flagSensor, RGB3,0x04);
	update_colors(flagSensor, RGB4,0x08);
}
