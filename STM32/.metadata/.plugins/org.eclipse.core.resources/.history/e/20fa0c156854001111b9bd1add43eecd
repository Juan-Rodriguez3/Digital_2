/* USER CODE BEGIN 4 */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    if (GPIO_Pin == Sens1_Pin)
    {
        uint8_t curr = HAL_GPIO_ReadPin(GPIOB, Sens1_Pin);

        if (prevSens1 == 1 && curr == 0)
        {
            ParqDisp--;
            EstadoParqueos |= (1 << 0);
            l_flag = 5;
        }
        else if (prevSens1 == 0 && curr == 1)
        {
            ParqDisp++;
            EstadoParqueos &= ~(1 << 0);
            l_flag = 13;
        }

        prevSens1 = curr;
    }
    else if (GPIO_Pin == Sens2_Pin)
    {
        uint8_t curr = HAL_GPIO_ReadPin(GPIOB, Sens2_Pin);

        if (prevSens2 == 1 && curr == 0)
        {
            ParqDisp--;
            EstadoParqueos |= (1 << 1);
            l_flag = 6;
        }
        else if (prevSens2 == 0 && curr == 1)
        {
            ParqDisp++;
            EstadoParqueos &= ~(1 << 1);
            l_flag = 14;
        }

        prevSens2 = curr;
    }
    else if (GPIO_Pin == Sens3_Pin)
    {
        uint8_t curr = HAL_GPIO_ReadPin(GPIOB, Sens3_Pin);

        if (prevSens3 == 1 && curr == 0)
        {
            ParqDisp--;
            EstadoParqueos |= (1 << 2);
            l_flag = 7;
        }
        else if (prevSens3 == 0 && curr == 1)
        {
            ParqDisp++;
            EstadoParqueos &= ~(1 << 2);
            l_flag = 15;
        }

        prevSens3 = curr;
    }
    else if (GPIO_Pin == Sens4_Pin)
    {
        uint8_t curr = HAL_GPIO_ReadPin(GPIOB, Sens4_Pin);

        if (prevSens4 == 1 && curr == 0)
        {
            ParqDisp--;
            EstadoParqueos |= (1 << 3);
            l_flag = 8;
        }
        else if (prevSens4 == 0 && curr == 1)
        {
            ParqDisp++;
            EstadoParqueos &= ~(1 << 3);
            l_flag = 16;
        }

        prevSens4 = curr;
    }
}
void HAL_I2C_ListenCpltCallback(I2C_HandleTypeDef *hi2c){
	HAL_I2C_EnableListen_IT(hi2c);
}

void HAL_I2C_AddrCallback(I2C_HandleTypeDef *hi2c, uint8_t TransferDirection, uint16_t AddrMatchCode){
	//Cuando el maestro quiere transmitir y el slave recibe
	if (TransferDirection == I2C_DIRECTION_TRANSMIT){
		if (HAL_I2C_Slave_Seq_Receive_IT(&hi2c1, (uint8_t*) aRxBuffer,2, I2C_FIRST_AND_LAST_FRAME) != HAL_OK )
		{
			Error_Handler();
		}
	}
	//Cuando el maestro quiere recebir y el slave transmite
	else if(TransferDirection == I2C_DIRECTION_RECEIVE) {
		if (HAL_I2C_Slave_Seq_Transmit_IT(&hi2c1, &aTxBuffer[0],1, I2C_FIRST_AND_LAST_FRAME) != HAL_OK )
			{
				Error_Handler();
			}
	}
}

void HAL_I2C_SlaveRxCpltCallback(I2C_HandleTypeDef *I2cHandle){
	i2c_last_activity = HAL_GetTick(); //Actualizar timestamp
	// Comando 'S' — solicitud de estado local
	    if (aRxBuffer[0] == 'S'){
	        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
	        aTxBuffer[0] = estadoParqueo;  // estado local de esta Nucleo
	    }
	    // Comando 'P' — ESP32 envía estado global de los 8 parqueos
	    else if (aRxBuffer[0] == 'P'){
	        estadoParqueo_ESP32 = aRxBuffer[1];  // guardar estado completo
	        flag_park_received = 1;              // avisar al while(1)
	        HAL_GPIO_TogglePin(LD2_GPIO_Port,LD2_Pin);
	    }

	    // Limpiar buffer
	    aRxBuffer[0] = 0x00;
	    aRxBuffer[1] = 0x00;
}

void HAL_I2C_SlaveTxCpltCallback(I2C_HandleTypeDef *I2cHandle){
	 i2c_last_activity = HAL_GetTick();  // actualizar timestamp también aquí
}

void HAL_I2C_ErrorCallback(I2C_HandleTypeDef *I2cHandle){


	if (HAL_I2C_GetError(I2cHandle) == HAL_I2C_ERROR_AF){
		// Error normal, re-habilitar escucha
		HAL_I2C_EnableListen_IT(I2cHandle);
	} else {

		//Primera contramedida para revivir el bus de I2C
		// Error grave — resetear el periférico SIN delays
		HAL_I2C_DeInit(I2cHandle);
		HAL_I2C_Init(I2cHandle);
		// 2. Re-habilitar escucha
		HAL_I2C_EnableListen_IT(I2cHandle);
		 i2c_error_flag = 1;
		// 3. Señal visual de que hubo error pero se recuperó
	}

}
