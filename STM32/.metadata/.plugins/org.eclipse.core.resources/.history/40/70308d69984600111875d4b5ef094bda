#include "i2c_slave.h"
#include <string.h>
#include <stdio.h>

static I2C_HandleTypeDef  *_hi2c;
static UART_HandleTypeDef *_huart;

static uint8_t regMap[REG_MAP_SIZE] = {
    0xAA, 0xBB, 0xCC, 0xDD,
    0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00
};

static uint8_t rxByte;           // recibe UN byte a la vez
static uint8_t txBuf[REG_MAP_SIZE];
static uint8_t currentReg  = 0;
static uint8_t rxByteCount = 0;  // cuántos bytes llevamos recibidos
static uint8_t isFirstByte = 1;  // el primer byte siempre es la dirección

static void UART_Print(const char *msg) {
    if (_huart == NULL) return;
    HAL_UART_Transmit(_huart, (uint8_t *)msg, strlen(msg), 100);
}

/* ── Init ────────────────────────────────────────────────── */
void I2C_Slave_Init(I2C_HandleTypeDef *hi2c, UART_HandleTypeDef *huart) {
    _hi2c  = hi2c;
    _huart = huart;
    HAL_I2C_EnableListen_IT(_hi2c);
    UART_Print("=== STM32 I2C3 Slave listo (0x42) ===\r\n");
}

/* ── AddrCallback: maestro inició transacción ────────────── */
void HAL_I2C_AddrCallback(I2C_HandleTypeDef *hi2c,
                           uint8_t TransferDirection,
                           uint16_t AddrMatchCode) {
    if (hi2c->Instance != I2C3) return;

    if (TransferDirection == I2C_DIRECTION_TRANSMIT) {
        // Maestro va a ESCRIBIR → recibir byte a byte
        UART_Print("[ADDR] Escribe\r\n");
        isFirstByte = 1;
        rxByteCount = 0;
        // Recibir UN solo byte con XFER_OPTIONS para manejar STOP correctamente
        HAL_I2C_Slave_Seq_Receive_IT(hi2c, &rxByte, 1,
                                      I2C_FIRST_FRAME);

    } else {
        // Maestro va a LEER → transmitir desde currentReg
        UART_Print("[ADDR] Lee\r\n");
        uint8_t available = REG_MAP_SIZE - currentReg;
        memcpy(txBuf, &regMap[currentReg], available);
        HAL_I2C_Slave_Seq_Transmit_IT(hi2c, txBuf, available,
                                       I2C_LAST_FRAME);
    }
}

/* ── RxCplt: llegó UN byte ───────────────────────────────── */
void HAL_I2C_SlaveRxCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;

    if (isFirstByte) {
        // Primer byte = dirección de registro
        currentReg  = rxByte;
        isFirstByte = 0;
        rxByteCount = 0;

        char buf[32];
        snprintf(buf, sizeof(buf), "[RX] Reg=0x%02X\r\n", currentReg);
        UART_Print(buf);
    } else {
        // Bytes siguientes = datos
        uint8_t regIdx = currentReg + rxByteCount;
        if (regIdx < REG_MAP_SIZE) {
            regMap[regIdx] = rxByte;

            char buf[32];
            snprintf(buf, sizeof(buf), "  [%d]=0x%02X\r\n",
                     regIdx, rxByte);
            UART_Print(buf);
        }
        rxByteCount++;
    }

    // Pedir el siguiente byte
    // Usamos NEXT_FRAME para que el periférico siga escuchando
    HAL_I2C_Slave_Seq_Receive_IT(hi2c, &rxByte, 1,
                                  I2C_NEXT_FRAME);
}

/* ── TxCplt: transmisión terminó ─────────────────────────── */
void HAL_I2C_SlaveTxCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;
    char buf[48];
    snprintf(buf, sizeof(buf), "[TX] Enviado desde Reg=0x%02X\r\n",
             currentReg);
    UART_Print(buf);
    HAL_I2C_EnableListen_IT(hi2c);
}

/* ── ListenCplt: STOP recibido ───────────────────────────── */
void HAL_I2C_ListenCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;
    UART_Print("[STOP] Transaccion completa\r\n");
    HAL_I2C_EnableListen_IT(hi2c);
}

/* ── ErrorCallback ───────────────────────────────────────── */
void HAL_I2C_ErrorCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;

    uint32_t error = HAL_I2C_GetError(hi2c);

    // AF es normal al terminar una lectura (el maestro no da ACK al último byte)
    if (error == HAL_I2C_ERROR_AF) {
        UART_Print("[AF] Fin de lectura OK\r\n");
        HAL_I2C_EnableListen_IT(hi2c);
        return;
    }

    char buf[48];
    snprintf(buf, sizeof(buf), "[ERROR] 0x%08lX\r\n", error);
    UART_Print(buf);

    // Reiniciar periférico limpiamente
    HAL_I2C_DeInit(hi2c);
    HAL_Delay(10);
    HAL_I2C_Init(hi2c);
    HAL_I2C_EnableListen_IT(hi2c);
}
