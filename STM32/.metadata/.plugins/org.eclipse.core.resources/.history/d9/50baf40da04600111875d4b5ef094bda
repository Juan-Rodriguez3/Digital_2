#include "i2c_slave.h"
#include <string.h>
#include <stdio.h>

static I2C_HandleTypeDef  *_hi2c;
static UART_HandleTypeDef *_huart;

static uint8_t regMap[REG_MAP_SIZE] = {
    0xAA, 0xBB, 0xCC, 0xDD,
    0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00
};

// Buffer: 1 byte reg + 4 bytes datos (lo que manda el ESP32)
#define RX_BUF_SIZE  5
static uint8_t rxBuf[RX_BUF_SIZE];
static uint8_t txBuf[REG_MAP_SIZE];
static uint8_t currentReg = 0;

static void UART_Print(const char *msg) {
    if (_huart == NULL) return;
    HAL_UART_Transmit(_huart, (uint8_t *)msg, strlen(msg), 100);
}

/* ── Init ────────────────────────────────────────────────── */
void I2C_Slave_Init(I2C_HandleTypeDef *hi2c, UART_HandleTypeDef *huart) {
    _hi2c  = hi2c;
    _huart = huart;
    HAL_I2C_EnableListen_IT(_hi2c);
    UART_Print("=== STM32 I2C3 Slave listo (0x42) ===\r\n");
}

/* ── AddrCallback ────────────────────────────────────────── */
void HAL_I2C_AddrCallback(I2C_HandleTypeDef *hi2c,
                           uint8_t TransferDirection,
                           uint16_t AddrMatchCode) {
    if (hi2c->Instance != I2C3) return;

    if (TransferDirection == I2C_DIRECTION_TRANSMIT) {
        UART_Print("[ADDR] Escribe\r\n");
        memset(rxBuf, 0, sizeof(rxBuf));
        // Recibir exactamente lo que manda el ESP32: reg + 4 datos
        HAL_I2C_Slave_Receive_IT(hi2c, rxBuf, RX_BUF_SIZE);

    } else {
        UART_Print("[ADDR] Lee\r\n");
        uint8_t available = REG_MAP_SIZE - currentReg;
        memcpy(txBuf, &regMap[currentReg], available);
        HAL_I2C_Slave_Transmit_IT(hi2c, txBuf, available);
    }
}

/* ── RxCplt: recibió los 5 bytes completos ───────────────── */
void HAL_I2C_SlaveRxCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;

    currentReg = rxBuf[0];  // primer byte = registro

    char buf[48];
    snprintf(buf, sizeof(buf), "[RX] Reg=0x%02X | ", currentReg);
    UART_Print(buf);

    // Escribir datos en el mapa
    for (uint8_t i = 1; i < RX_BUF_SIZE; i++) {
        uint8_t idx = currentReg + (i - 1);
        if (idx >= REG_MAP_SIZE) break;
        regMap[idx] = rxBuf[i];
        snprintf(buf, sizeof(buf), "0x%02X ", rxBuf[i]);
        UART_Print(buf);
    }
    UART_Print("\r\n");

    HAL_I2C_EnableListen_IT(hi2c);
}

/* ── TxCplt ──────────────────────────────────────────────── */
void HAL_I2C_SlaveTxCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;
    char buf[48];
    snprintf(buf, sizeof(buf), "[TX] Desde Reg=0x%02X\r\n", currentReg);
    UART_Print(buf);
    HAL_I2C_EnableListen_IT(hi2c);
}

/* ── ListenCplt: STOP ────────────────────────────────────── */
void HAL_I2C_ListenCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;
    UART_Print("[STOP]\r\n");
    HAL_I2C_EnableListen_IT(hi2c);
}

/* ── ErrorCallback ───────────────────────────────────────── */
void HAL_I2C_ErrorCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance != I2C3) return;

    uint32_t error = HAL_I2C_GetError(hi2c);

    if (error == HAL_I2C_ERROR_AF) {
        // AF en escritura = el maestro mandó MENOS bytes de los esperados
        // Procesar lo que llegó igual
        UART_Print("[AF] STOP anticipado - procesando datos recibidos\r\n");

        currentReg = rxBuf[0];
        char buf[48];
        snprintf(buf, sizeof(buf), "[RX-AF] Reg=0x%02X | ", currentReg);
        UART_Print(buf);

        for (uint8_t i = 1; i < RX_BUF_SIZE; i++) {
            uint8_t idx = currentReg + (i - 1);
            if (idx >= REG_MAP_SIZE) break;
            if (rxBuf[i] == 0 && i > 1) break;
            regMap[idx] = rxBuf[i];
            snprintf(buf, sizeof(buf), "0x%02X ", rxBuf[i]);
            UART_Print(buf);
        }
        UART_Print("\r\n");

        HAL_I2C_EnableListen_IT(hi2c);
        return;
    }

    char buf[48];
    snprintf(buf, sizeof(buf), "[ERROR] 0x%08lX\r\n", error);
    UART_Print(buf);
    HAL_I2C_DeInit(hi2c);
    HAL_Delay(10);
    HAL_I2C_Init(hi2c);
    HAL_I2C_EnableListen_IT(hi2c);
}
